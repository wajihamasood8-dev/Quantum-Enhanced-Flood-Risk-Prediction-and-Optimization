  "qubo_problem_setup": {
    "binary_variables": 16,
    "objective_terms": [
      "maximize early_warning_value",
      "maximize flood_frequency_coverage",
      "minimize redundancy violations",
      "penalize uncovered high-risk reaches"
    ]
  },
  "qml_flood_prediction": {
    "model_architecture": "Hybrid Quantum-Classical",
    "workflow": [
      "Step 1: QAOA sensor placement optimization (COMPLETED)",
      "Step 2: QML flood risk classification (CURRENT)",
      "Step 3: Integrated early warning system"
    ],
    "quantum_advantage_claim": {
      "problem_type": "Nonlinear classification in 7D feature space",
      "classical_challenge": "High-dimensional decision boundaries with limited training data",
      "quantum_solution": "Quantum kernel methods explore larger feature spaces via entanglement",
      "expected_benefit": "Better generalization on unseen flood events with small datasets"
    },
    "training_configuration": {
      "dataset": "qml_training_data.json",
      "total_samples": 291,
      "flood_class_samples": 97,
      "normal_class_samples": 194,
      "test_split": 0.2,
      "validation_split": 0.1,
      "features": [
        "prcp_3day_avg_mm",
        "prcp_7day_cumulative_mm",
        "upstream_discharge_m3s",
        "soil_saturation_index",
        "humidity_avg_pct",
        "temp_range_c",
        "antecedent_moisture_index"
      ],
      "target": "binary (0=NO_FLOOD, 1=FLOOD)",
      "feature_separability": {
        "prcp_3day_avg_mm": "1.97\u03c3 separation",
        "soil_saturation_index": "1.96\u03c3 separation",
        "upstream_discharge_m3s": "1.71\u03c3 separation",
        "note": "Strong separability indicates quantum kernel advantage is plausible"
      }
    },
    "quantum_ml_method": {
      "approach": "Quantum Kernel Support Vector Machine",
      "quantum_circuit": {
        "feature_map": "ZZFeatureMap",
        "reps": 2,
        "entanglement": "linear",
        "qubits_required": 7,
        "circuit_depth": "~20 gates"
      },
      "backend": "qiskit_aer.AerSimulator",
      "shots": 1024,
      "classical_baseline": "RBF Kernel SVM"
    },
    "evaluation_metrics": {
      "primary": "F1-score (flood class)",
      "critical_metric": "Recall (minimize false negatives - missed floods)",
      "target_performance": {
        "classical_baseline": "82-88% accuracy",
        "quantum_goal": ">90% accuracy, >92% flood recall"
      }
    },
    "deployment_scenario": {
      "real_time_prediction": "Given current hydro-met conditions \u2192 predict flood risk in next 6-24 hours",
      "input_pipeline": "Weather stations + river gauges \u2192 feature vector \u2192 quantum kernel \u2192 risk score",
      "integration_with_qaoa": "Optimally placed sensors (from QAOA) \u2192 feed data \u2192 QML prediction"
    }
  },
